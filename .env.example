# ── Groq LLM (groq.com) ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Qdrant Vector Store ──────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=company_docs

# ── Odoo ERP ─────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USERNAME=api_user
ODOO_PASSWORD=api_password

# ── n8n Automation ───────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://your-n8n-instance.com/webhook
N8N_API_KEY=your_n8n_api_key

# ── Redis (Session Store & Cache) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600
REDIS_MAX_CONNECTIONS=20

# ── PostgreSQL (Audit Log & Persistence) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://basira:basira@localhost:5432/basira
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Connection Pooling ───────────────────────────────────────────────────
ODOO_POOL_SIZE=5
ODOO_POOL_TIMEOUT=30
QDRANT_POOL_SIZE=5

# ── Application ──────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production

# ── Internal ─────────────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-in-production
