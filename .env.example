# ── Groq LLM (groq.com) ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Voice (ASR + TTS via Groq) ───────────────────────────────────────────
# ASR: Whisper V3 Large ($0.111/hr transcribed)
# TTS: Orpheus Arabic Saudi ($40/M characters)
# Both use the same GROQ_API_KEY above
VOICE_ASR_MODEL=whisper-large-v3
VOICE_TTS_MODEL=canopylabs/orpheus-arabic-saudi
VOICE_TTS_VOICE=tara

# ── Embeddings (Multi-provider) ────────────────────────────────────────────
# Priority: OPENAI_API_KEY → JINA_API_KEY → EMBEDDING_LOCAL_MODEL → Placeholder
#
# Option 1: OpenAI (recommended for production)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=          # Uncomment for Azure/custom endpoints
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_CACHE_TTL=604800   # 7 days

# Option 2: Jina AI (excellent for Arabic, cheaper than OpenAI)
# JINA_API_KEY=jina_...
# JINA_MODEL=jina-embeddings-v3

# Option 3: Local sentence-transformers (offline, free)
# EMBEDDING_LOCAL_MODEL=all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu

# ── Qdrant Vector Store ──────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=company_docs

# ── Odoo ERP ─────────────────────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USERNAME=api_user
ODOO_PASSWORD=api_password

# ── n8n Automation ───────────────────────────────────────────────────────
N8N_WEBHOOK_BASE=https://your-n8n-instance.com/webhook
N8N_API_KEY=your_n8n_api_key

# ── Redis (Session Store & Cache) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600
REDIS_MAX_CONNECTIONS=20

# ── PostgreSQL (Audit Log & Persistence) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://basira:basira@localhost:5432/basira
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Connection Pooling ───────────────────────────────────────────────────
ODOO_POOL_SIZE=5
ODOO_POOL_TIMEOUT=30
QDRANT_POOL_SIZE=5

# ── Application ──────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-in-production

# ── Internal ─────────────────────────────────────────────────────────────
INTERNAL_API_KEY=change-me-in-production

# ── Rate Limiting ────────────────────────────────────────────────────────
# Algorithm: sliding_window (default), token_bucket, fixed_window
RATE_LIMIT_ALGORITHM=sliding_window
RATE_LIMIT_DEFAULT=60           # Default requests per window
RATE_LIMIT_WINDOW=60            # Window size in seconds
